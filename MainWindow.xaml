<Window x:Class="PrivatUtilities.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        Title="Коммунальные счета" Height="720" Width="1040"
        WindowStartupLocation="CenterScreen" FontFamily="Segoe UI" FontSize="13">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        <Style x:Key="FieldLabel" TargetType="TextBlock">
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="Foreground" Value="#FF999999"/>
            <Setter Property="Margin" Value="2,0,0,1"/>
        </Style>
        <Style x:Key="Edit" TargetType="TextBox">
            <Setter Property="Padding" Value="4,3"/>
            <Setter Property="BorderBrush" Value="#FFD5E2DA"/>
        </Style>
    </Window.Resources>

    <DockPanel>
        <Border DockPanel.Dock="Top" Background="#FF1F6E43" Padding="14,10">
            <TextBlock Text="Коммунальные платежи" Foreground="White" FontSize="17" FontWeight="Bold"/>
        </Border>

        <TabControl x:Name="Tabs" BorderThickness="0" Padding="0" Background="White">

            <!-- ВКЛАДКА 1: справочник предприятий (редактируемый) -->
            <TabItem Header="🏢 Предприятия">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Адрес + область + действия -->
                    <Border Grid.Row="0" Background="#FFEAF2EC" Padding="12,10"
                            BorderBrush="#FFD5E2DA" BorderThickness="0,0,0,1">
                        <StackPanel>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Адрес:" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                <TextBox Grid.Column="1" x:Name="TxtAddressBox" Style="{StaticResource Edit}"
                                         LostFocus="Field_LostFocus" VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="2" Text="Область:" VerticalAlignment="Center" Margin="12,0,6,0"/>
                                <ComboBox Grid.Column="3" x:Name="CmbRegion" Width="180" VerticalAlignment="Center"/>
                            </Grid>
                            <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                                <Button x:Name="BtnSuggest" Content="🔎 Подставить по области" Click="BtnSuggest_Click"
                                        Padding="12,5" Background="White" BorderBrush="#FFCCD8D0" Cursor="Hand"/>
                                <Button x:Name="BtnAdd" Content="➕ Добавить поставщика" Click="BtnAdd_Click"
                                        Padding="12,5" Margin="8,0,0,0" Background="White" BorderBrush="#FFCCD8D0" Cursor="Hand"/>
                                <Button x:Name="BtnSaveAccounts" Content="💾 Сохранить" Click="BtnSaveAccounts_Click"
                                        Padding="12,5" Margin="8,0,0,0" Background="White" BorderBrush="#FFCCD8D0" Cursor="Hand"/>
                                <TextBlock Text="Названия по области — это черновик-подсказка, проверьте и поправьте."
                                           Foreground="#FF6B8576" FontSize="11" VerticalAlignment="Center" Margin="12,0,0,0"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <Border Grid.Row="1" Background="#FFF7FAF8" Padding="12,4" BorderBrush="#FFE6EFE9" BorderThickness="0,0,0,1">
                        <TextBlock x:Name="TxtListInfo" Text="" Foreground="#FF777777" FontSize="11"/>
                    </Border>

                    <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto" Padding="10">
                        <ItemsControl x:Name="ProvidersList">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Margin="0,0,0,8" Padding="12,10" CornerRadius="6"
                                            Background="#FFF9FBFA" BorderBrush="#FFE3ECE6" BorderThickness="1">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="210"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>

                                            <!-- Услуга -->
                                            <StackPanel Grid.Column="0" VerticalAlignment="Center" Margin="0,0,8,0">
                                                <TextBlock Text="услуга" Style="{StaticResource FieldLabel}"/>
                                                <TextBox Text="{Binding Service, UpdateSourceTrigger=PropertyChanged}"
                                                         Style="{StaticResource Edit}" LostFocus="Field_LostFocus"
                                                         FontWeight="SemiBold" Foreground="#FF1F6E43"/>
                                            </StackPanel>

                                            <!-- Компания + сайт -->
                                            <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="0,0,8,0">
                                                <TextBlock Text="предприятие" Style="{StaticResource FieldLabel}"/>
                                                <TextBox Text="{Binding Company, UpdateSourceTrigger=PropertyChanged}"
                                                         Style="{StaticResource Edit}" LostFocus="Field_LostFocus"
                                                         TextWrapping="Wrap"/>
                                                <TextBlock Text="сайт" Style="{StaticResource FieldLabel}" Margin="2,4,0,1"/>
                                                <DockPanel>
                                                    <Button DockPanel.Dock="Right" Content="↗" ToolTip="Открыть сайт"
                                                            Click="OpenUrl_Click" Padding="8,2" Margin="4,0,0,0"
                                                            Background="White" BorderBrush="#FFCCD8D0" Cursor="Hand"/>
                                                    <TextBox Text="{Binding Url, UpdateSourceTrigger=PropertyChanged}"
                                                             Style="{StaticResource Edit}" LostFocus="Field_LostFocus"/>
                                                </DockPanel>
                                            </StackPanel>

                                            <!-- Лицевой счёт + копировать -->
                                            <StackPanel Grid.Column="2" VerticalAlignment="Center" Margin="0,0,8,0">
                                                <TextBlock Text="лицевой счёт" Style="{StaticResource FieldLabel}"/>
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBox Text="{Binding Account, UpdateSourceTrigger=PropertyChanged}"
                                                             Style="{StaticResource Edit}" LostFocus="Field_LostFocus"
                                                             Width="140" FontFamily="Consolas" FontSize="14"/>
                                                    <Button Content="⧉" ToolTip="Копировать счёт в буфер обмена"
                                                            Click="CopyAccount_Click" Padding="8,3" Margin="4,0,0,0"
                                                            Background="White" BorderBrush="#FFCCD8D0" Cursor="Hand"/>
                                                </StackPanel>
                                            </StackPanel>

                                            <!-- Удалить -->
                                            <Button Grid.Column="3" Content="🗑" ToolTip="Удалить поставщика"
                                                    Click="DeleteProvider_Click" VerticalAlignment="Center"
                                                    Padding="8,4" Background="White" BorderBrush="#FFE0C8C8"
                                                    Foreground="#FFB00020" Cursor="Hand"/>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
            </TabItem>

            <!-- ВКЛАДКА 2: Privat24 -->
            <TabItem Header="🔐 Privat24">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Border Grid.Row="0" Background="#FFF3F6F4" Padding="10,8"
                            BorderBrush="#FFE0E0E0" BorderThickness="0,0,0,1">
                        <DockPanel>
                            <StackPanel Orientation="Horizontal" DockPanel.Dock="Right">
                                <Button x:Name="BtnHome" Content="🏠 На главную" Click="BtnHome_Click"
                                        Padding="12,6" Margin="6,0,0,0" Background="White" BorderBrush="#FFCCD8D0" Cursor="Hand"/>
                                <Button x:Name="BtnLogout" Content="🚪 Выйти" Click="BtnLogout_Click"
                                        Padding="12,6" Margin="6,0,0,0" Background="White" BorderBrush="#FFCCD8D0" Cursor="Hand"/>
                                <Button x:Name="BtnRefresh" Content="🔄 Обновить" Click="BtnRefresh_Click"
                                        Padding="14,6" Margin="6,0,0,0" FontWeight="SemiBold"
                                        Background="#FF1F6E43" Foreground="White" BorderThickness="0" Cursor="Hand"/>
                            </StackPanel>
                            <TextBlock x:Name="TxtStatus" Text="Готов к загрузке…" Foreground="#FF555555" VerticalAlignment="Center"/>
                        </DockPanel>
                    </Border>
                    <wv2:WebView2 Grid.Row="1" x:Name="Web" Loaded="Web_Loaded"/>
                    <Border Grid.Row="2" Background="#FFF3F6F4" Padding="10,5"
                            BorderBrush="#FFE0E0E0" BorderThickness="0,1,0,0">
                        <DockPanel>
                            <Button x:Name="BtnDump" Content="Диагностика: сохранить HTML" Click="BtnDump_Click"
                                    DockPanel.Dock="Right" Padding="8,3" Background="Transparent"
                                    BorderBrush="#FFCCCCCC" Foreground="#FF777777" FontSize="11" Cursor="Hand"/>
                            <TextBlock Text="Войдите в Privat24 один раз — сессия сохранится для следующих запусков."
                                       Foreground="#FF888888" FontSize="11" VerticalAlignment="Center"/>
                        </DockPanel>
                    </Border>
                </Grid>
            </TabItem>

            <!-- ВКЛАДКА 3: другой банк / агрегатор -->
            <TabItem Header="💳 Другой банк">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <Border Grid.Row="0" Background="#FFF3F6F4" Padding="10,8"
                            BorderBrush="#FFE0E0E0" BorderThickness="0,0,0,1">
                        <DockPanel>
                            <StackPanel Orientation="Horizontal" DockPanel.Dock="Right">
                                <Button x:Name="BtnRefreshBank" Content="🔄 Обновить" Click="BtnRefreshBank_Click"
                                        Padding="12,6" Margin="6,0,0,0" Background="White" BorderBrush="#FFCCD8D0" Cursor="Hand"/>
                                <Button x:Name="BtnOpenBank" Content="Открыть ▶" Click="BtnOpenBank_Click"
                                        Padding="14,6" Margin="6,0,0,0" FontWeight="SemiBold"
                                        Background="#FF1F6E43" Foreground="White" BorderThickness="0" Cursor="Hand"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBlock Text="Сервис:" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                <ComboBox x:Name="CmbBank" Width="280" VerticalAlignment="Center"/>
                                <TextBlock x:Name="TxtBankStatus" Text="" Foreground="#FF777777"
                                           VerticalAlignment="Center" Margin="12,0,0,0"/>
                            </StackPanel>
                        </DockPanel>
                    </Border>
                    <wv2:WebView2 Grid.Row="1" x:Name="WebBank" Loaded="WebBank_Loaded"/>
                </Grid>
            </TabItem>
        </TabControl>
    </DockPanel>
</Window>
